#!/bin/bash

REPO_ROOT=$(git rev-parse --show-toplevel)

# Build catastrophes app
echo "Building catastrophes app..."
cd "$REPO_ROOT/catastrophes-app" || exit 1
npm run build
if [ $? -ne 0 ]; then
  echo "Catastrophes app build failed. Aborting commit."
  exit 1
fi
git add dist/

# Build diagram app
echo "Building diagram app..."
cd "$REPO_ROOT/diagram-app" || exit 1
NODE_ENV=production npm run build
if [ $? -ne 0 ]; then
  echo "Diagram app build failed. Aborting commit."
  exit 1
fi
git add dist/

echo "All builds complete. Proceeding with commit."
exit 0
